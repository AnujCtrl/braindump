{
  "name": "braindump",
  "version": "2.0.0",
  "description": "Todo capture system with Linear integration",
  "type": "module",
  "bin": {
    "braindump": "src/cli/index.ts"
  },
  "scripts": {
    "build": "bun build --compile src/cli/index.ts --outfile dist/braindump",
    "dev": "bun run src/cli/index.ts",
    "server": "bun run src/server/index.ts",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.1",
    "@linear/sdk": "^37.0.0",
    "commander": "^13.1.0",
    "fastify": "^5.3.2",
    "yaml": "^2.7.1"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.2"
  }
}
